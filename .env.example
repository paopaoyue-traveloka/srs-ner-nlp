# WandB 配置模板
# 复制本文件为 .env，填入真实值，.env 已在 .gitignore 中不会提交。
#
# 获取 API key：https://wandb.ai/authorize
# 或运行 `wandb login` 通过浏览器登录（会写入 ~/.netrc，同样无需在此填写）。

WANDB_API_KEY=your_api_key_here

# WandB 项目名称（--wandb_project 命令行参数优先级更高）
WANDB_PROJECT=ner-finetune

# WandB 团队/用户名，留空则使用账号默认值（--wandb_entity 命令行参数优先级更高）
WANDB_ENTITY=
